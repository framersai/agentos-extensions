{
  "name": "@framers/agentos-ext-citation-verifier",
  "version": "0.1.0",
  "description": "Verify claims in text against sources using semantic similarity with optional web fallback",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": { "build": "tsc", "test": "vitest run", "clean": "rimraf dist" },
  "peerDependencies": { "@framers/agentos": "^0.2.10" },
  "keywords": ["agentos", "extension", "citation", "verification", "semantic-similarity"],
  "license": "MIT",
  "publishConfig": { "access": "public" }
}
