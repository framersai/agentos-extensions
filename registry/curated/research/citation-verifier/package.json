{
  "name": "@framers/agentos-ext-citation-verifier",
  "version": "0.1.0",
  "description": "Verify claims in text against sources using semantic similarity with optional web fallback",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.6.6"
  },
  "keywords": [
    "agentos",
    "extension",
    "citation",
    "verification",
    "semantic-similarity"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/research/citation-verifier"
  },
  "homepage": "https://github.com/framersai/agentos-extensions/tree/master/registry/curated/research/citation-verifier#readme",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md"
  ]
}
