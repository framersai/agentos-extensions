{
  "name": "@framers/agentos-ext-cloud-aws",
  "version": "0.1.0",
  "description": "AWS cloud extension \u2014 deploy static sites to S3, manage Lightsail instances, configure Route53 DNS, deploy via Amplify, set up CloudFront distributions, and deploy Lambda functions using direct REST API calls with SigV4 signing.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "cloud",
    "aws",
    "s3",
    "lambda",
    "lightsail",
    "route53",
    "amplify",
    "cloudfront"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "contributors": [
    {
      "name": "Johnny Dunn",
      "email": "johnnyfived@protonmail.com",
      "url": "https://github.com/jddunn"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/cloud/aws"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.5.2"
  },
  "devDependencies": {
    "@framers/agentos": "^0.6.6",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/framersai/agentos-extensions/tree/master/registry/curated/cloud/aws#readme",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  },
  "files": [
    "dist",
    "manifest.json"
  ]
}
