{
  "name": "@framers/agentos-ext-cloud-vercel",
  "version": "0.1.0",
  "description": "Vercel cloud deployment extension — deploy projects, manage domains, and configure environment variables via the Vercel REST API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "cloud",
    "vercel",
    "deploy",
    "hosting"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "contributors": [
    {
      "name": "Johnny Dunn",
      "email": "johnnyfived@protonmail.com",
      "url": "https://github.com/jddunn"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/cloud/vercel"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.2.11"
  },
  "devDependencies": {
    "@framers/agentos": "workspace:^",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
