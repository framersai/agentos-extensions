{
  "name": "@framers/agentos-ext-cloud-cloudflare-pages",
  "version": "0.1.0",
  "description": "Cloudflare Pages cloud extension — deploy Pages projects, manage DNS records, and deploy Workers via the Cloudflare API v4.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": ["agentos", "extension", "cloud", "cloudflare", "pages", "workers", "dns", "deploy", "hosting"],
  "author": { "name": "Framers AI", "email": "team@frame.dev", "url": "https://frame.dev" },
  "contributors": [{ "name": "Johnny Dunn", "email": "johnnyfived@protonmail.com", "url": "https://github.com/jddunn" }],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/framersai/agentos-extensions.git", "directory": "registry/curated/cloud/cloudflare-pages" },
  "publishConfig": { "access": "public" },
  "peerDependencies": { "@framers/agentos": "^0.1.0" },
  "devDependencies": {
    "@framers/agentos": "^0.1.0",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
