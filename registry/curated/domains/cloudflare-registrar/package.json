{
  "name": "@framers/agentos-ext-domain-cloudflare-registrar",
  "version": "0.1.0",
  "description": "Cloudflare Registrar extension \u2014 list, inspect, and manage domains and DNS records via the Cloudflare API v4.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "domain",
    "cloudflare",
    "registrar",
    "dns",
    "transfer"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "contributors": [
    {
      "name": "Johnny Dunn",
      "email": "johnnyfived@protonmail.com",
      "url": "https://github.com/jddunn"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/domains/cloudflare-registrar"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.6.6"
  },
  "devDependencies": {
    "@framers/agentos": "^0.6.6",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/framersai/agentos-extensions/tree/master/registry/curated/domains/cloudflare-registrar#readme",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  },
  "files": [
    "dist",
    "manifest.json"
  ]
}
