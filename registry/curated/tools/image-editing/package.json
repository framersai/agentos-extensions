{
  "name": "@framers/agentos-ext-image-editing",
  "version": "0.1.0",
  "description": "Image editing extension for AgentOS \u2014 img2img, inpainting, outpainting, upscaling, and variations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "image-editing",
    "img2img",
    "inpainting",
    "upscaling"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "contributors": [
    {
      "name": "Johnny Dunn",
      "email": "johnnyfived@protonmail.com",
      "url": "https://github.com/jddunn"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/tools/image-editing"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.5.2"
  },
  "devDependencies": {
    "@framers/agentos": "^0.5.2",
    "@types/node": "^20.12.12",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/framersai/agentos-extensions/tree/master/registry/curated/tools/image-editing#readme",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  }
}
