{
  "name": "@framers/agentos-ext-wallet",
  "version": "0.2.0",
  "description": "Agent Personal Wallet — autonomous crypto spending with guardrails, multi-chain support (Solana + EVM), and virtual card integration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "wallet",
    "crypto",
    "solana",
    "ethereum",
    "spending-policy",
    "guardrails"
  ],
  "author": {
    "name": "Frame.dev",
    "email": "support@frame.dev",
    "url": "https://github.com/framersai"
  },
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.2.5",
    "@solana/web3.js": "^1.0.0",
    "@solana/spl-token": "^0.3.0",
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": { "optional": true },
    "@solana/spl-token": { "optional": true },
    "ethers": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
