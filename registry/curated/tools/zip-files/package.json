{
  "name": "@framers/agentos-ext-zip-files",
  "version": "0.1.0",
  "description": "Create zip archives from local files for easy sharing via chat channels",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "archiver": "^7.0.0"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.5.2"
  },
  "keywords": [
    "agentos",
    "extension",
    "tool",
    "zip",
    "archive"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/tools/zip-files"
  },
  "homepage": "https://github.com/framersai/agentos-extensions/tree/master/registry/curated/tools/zip-files#readme",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  },
  "files": [
    "dist",
    "manifest.json",
    "README.md"
  ]
}
