{
  "name": "@framers/agentos-ext-verify",
  "version": "1.0.0",
  "description": "Discord verification — link Discord accounts to RabbitHole subscriptions and sync roles",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.1.0",
    "discord.js": "^14.0.0"
  },
  "devDependencies": {
    "@framers/agentos": "^0.1.0",
    "@types/node": "^20.12.12",
    "discord.js": "^14.16.3",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions.git",
    "directory": "registry/curated/community/verify"
  },
  "publishConfig": { "access": "public" },
  "keywords": ["agentos", "extension", "verify", "discord", "rabbithole"]
}
