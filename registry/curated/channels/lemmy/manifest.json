{
  "$schema": "https://agentos.sh/schemas/extension-manifest-v1.json",
  "id": "com.framers.channels.lemmy",
  "name": "Lemmy Channel Extension",
  "version": "0.1.0",
  "description": "Bidirectional Lemmy integration — create posts, comment, vote, search, subscribe to communities, and browse feeds via Lemmy HTTP API.",
  "categories": ["channel", "social"],
  "platforms": ["lemmy"],
  "sdk": "lemmy-http-api",
  "extensions": [
    { "kind": "tool", "id": "lemmyPost", "displayName": "Create Post" },
    { "kind": "tool", "id": "lemmyComment", "displayName": "Create Comment" },
    { "kind": "tool", "id": "lemmyVote", "displayName": "Vote" },
    { "kind": "tool", "id": "lemmySearch", "displayName": "Search" },
    { "kind": "tool", "id": "lemmySubscribe", "displayName": "Subscribe to Community" },
    { "kind": "tool", "id": "lemmyFeed", "displayName": "Get Feed" },
    { "kind": "messaging-channel", "id": "lemmyChannel", "displayName": "Lemmy Channel Adapter" }
  ],
  "requiredSecrets": ["lemmy.instanceUrl", "lemmy.username", "lemmy.password"],
  "optionalSecrets": [],
  "features": [
    "Create posts with text, body, and URL links",
    "Comment on posts with threaded replies",
    "Upvote, downvote, and reset votes on posts and comments",
    "Search posts, comments, and communities",
    "Subscribe and unsubscribe from communities",
    "Browse feeds by type (All, Local, Subscribed) and sort order"
  ]
}
