{
  "name": "@framers/agentos-ext-channel-blog-publisher",
  "version": "0.1.0",
  "description": "Unified blog publishing channel adapter for AgentOS — publishes to Dev.to, Hashnode, Medium, and WordPress from a single interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agentos",
    "extension",
    "channel",
    "blog",
    "devto",
    "hashnode",
    "medium",
    "wordpress",
    "publishing",
    "cross-posting"
  ],
  "author": {
    "name": "Framers AI",
    "url": "https://frame.dev"
  },
  "license": "MIT",
  "files": [
    "dist",
    "manifest.json"
  ],
  "peerDependencies": {
    "@framers/agentos": "^0.2.11"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@framers/agentos": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions",
    "directory": "registry/curated/channels/blog-publisher"
  }
}
