{
  "name": "@framers/agentos-ext-channel-mastodon",
  "version": "0.1.0",
  "description": "Mastodon channel adapter for AgentOS — post statuses, reply, boost, favourite, search, trending, follow, and engagement analytics via the Mastodon API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@framers/agentos": "^0.2.4"
  },
  "dependencies": {
    "masto": "^6.8.0"
  },
  "devDependencies": {
    "@framers/agentos": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions",
    "directory": "registry/curated/channels/mastodon"
  }
}
