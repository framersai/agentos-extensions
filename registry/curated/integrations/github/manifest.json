{
  "$schema": "https://agentos.sh/schemas/extension-manifest-v1.json",
  "id": "com.framers.integrations.github",
  "name": "GitHub Extension",
  "version": "0.1.0",
  "description": "GitHub API tools — 26 tools for repos, issues, PRs, branches, commits, releases, Actions, files, gists, and codebase indexing.",
  "categories": ["tool", "developer"],
  "extensions": [
    { "kind": "tool", "id": "githubSearch", "displayName": "GitHub Search" },
    { "kind": "tool", "id": "githubIssueList", "displayName": "List GitHub Issues" },
    { "kind": "tool", "id": "githubIssueCreate", "displayName": "Create GitHub Issue" },
    { "kind": "tool", "id": "githubPrList", "displayName": "List GitHub PRs" },
    { "kind": "tool", "id": "githubPrCreate", "displayName": "Create GitHub PR" },
    { "kind": "tool", "id": "githubFileRead", "displayName": "Read GitHub File" },
    { "kind": "tool", "id": "githubGistCreate", "displayName": "Create GitHub Gist" },
    { "kind": "tool", "id": "repoList", "displayName": "GitHub Repo List" },
    { "kind": "tool", "id": "repoInfo", "displayName": "GitHub Repo Info" },
    { "kind": "tool", "id": "repoCreate", "displayName": "GitHub Repo Create" },
    { "kind": "tool", "id": "repoIndex", "displayName": "GitHub Repo Index" },
    { "kind": "tool", "id": "fileWrite", "displayName": "GitHub File Write" },
    { "kind": "tool", "id": "branchList", "displayName": "GitHub Branch List" },
    { "kind": "tool", "id": "branchCreate", "displayName": "GitHub Branch Create" },
    { "kind": "tool", "id": "commitList", "displayName": "GitHub Commit List" },
    { "kind": "tool", "id": "issueUpdate", "displayName": "GitHub Issue Update" },
    { "kind": "tool", "id": "commentList", "displayName": "GitHub Comment List" },
    { "kind": "tool", "id": "prDiff", "displayName": "GitHub PR Diff" },
    { "kind": "tool", "id": "prReview", "displayName": "GitHub PR Review" },
    { "kind": "tool", "id": "prMerge", "displayName": "GitHub PR Merge" },
    { "kind": "tool", "id": "prCommentList", "displayName": "GitHub PR Comment List" },
    { "kind": "tool", "id": "prCommentCreate", "displayName": "GitHub PR Comment Create" },
    { "kind": "tool", "id": "releaseList", "displayName": "GitHub Release List" },
    { "kind": "tool", "id": "releaseCreate", "displayName": "GitHub Release Create" },
    { "kind": "tool", "id": "actionsList", "displayName": "GitHub Actions List" },
    { "kind": "tool", "id": "actionsTrigger", "displayName": "GitHub Actions Trigger" }
  ],
  "requiredSecrets": ["github.token"],
  "features": [
    "Repository, code, and issue search",
    "Repository listing, info, creation, and codebase indexing",
    "Issue listing, creation, and updating",
    "Pull request listing, creation, diff, review, merge, and comments",
    "Branch listing and creation",
    "Commit history listing",
    "File reading and writing",
    "Release listing and creation",
    "GitHub Actions workflow listing and triggering",
    "Gist creation"
  ]
}
