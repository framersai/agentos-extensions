{
  "name": "@framers/agentos-extensions",
  "version": "1.0.3",
  "files": [
    "index.mjs",
    "registry.json",
    "types.d.ts",
    "README.md"
  ],
  "description": "Extension source for AgentOS — implementations, templates, and manifests for tools, channel adapters, and integrations. Companion to the @framers/agentos TypeScript AI agent runtime.",
  "homepage": "https://agentos.sh",
  "bugs": {
    "url": "https://github.com/framersai/agentos-extensions/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./index.mjs",
      "types": "./types.d.ts"
    },
    "./registry.json": "./registry.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/build-extensions.js && node scripts/update-registry.js",
    "create-extension": "node scripts/create-extension.js",
    "update-registry": "node scripts/update-registry.js",
    "docs": "npx typedoc",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions.git"
  },
  "keywords": [
    "agentos",
    "framers-agentos",
    "agentos-extensions",
    "agentos-tools",
    "extensions",
    "plugins",
    "tools",
    "tool-use",
    "tool-calling",
    "ai-agent",
    "ai-agents",
    "ai-agent-tools",
    "agent-framework",
    "agent-tools",
    "channel-adapters",
    "discord-bot",
    "telegram-bot",
    "slack-bot",
    "whatsapp-bot",
    "webchat",
    "browser-automation",
    "web-search",
    "voice-synthesis",
    "framers",
    "frame-dev"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "contributors": [
    {
      "name": "Johnny Dunn",
      "email": "johnnyfived@protonmail.com",
      "url": "https://github.com/jddunn"
    }
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@atproto/api": "^0.13.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "masto": "^6.8.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.5"
  }
}